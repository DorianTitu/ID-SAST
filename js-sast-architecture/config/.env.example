# Server Configuration
PORT=3000
NODE_ENV=development

# Google Gemini API Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your_api_key_here

# MongoDB Configuration
# Get your connection string from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp
MONGODB_DB_NAME=js-sast
MONGODB_RULES_COLLECTION=security_rules
MONGODB_ANALYSIS_COLLECTION=analyses

# Storage Configuration (Local Fallback)
STORAGE_DIR=./data
RULES_DIR=./data/rules

# Analysis Configuration
ANALYSIS_TIMEOUT=30000
MAX_CODE_SIZE=1000000

# Logging Configuration
LOG_LEVEL=info
VERBOSE_LOGGING=false

# Feature Flags
USE_GEMINI=true
USE_PERSISTENCE=true
USE_ADVANCED_ANALYSIS=true
USE_MONGODB=true
